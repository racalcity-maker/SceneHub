menu "SceneHub Node board profile"

config SCENEHUB_NODE_FACTORY_PIN_PROFILE
    bool "Enable factory pin profile"
    default n
    help
        Enable compile-time factory pin configuration for boxed hardware.
        When disabled, functional pins stay disabled by default and can be
        configured through provisioning/runtime config.

config SCENEHUB_NODE_FACTORY_PIN_LOCKED
    bool "Lock pin configuration in UI/API"
    depends on SCENEHUB_NODE_FACTORY_PIN_PROFILE
    default y
    help
        Mark pin configuration as factory-owned. Provisioning UI should hide or
        disable pin editing when this option is enabled.

