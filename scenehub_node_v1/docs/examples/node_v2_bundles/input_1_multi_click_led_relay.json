    {
      "id": "boot_init",
      "enabled": true,
      "trigger": {
        "kind": "boot"
      },
      "actions": [
        {
          "kind": "cancel_timer",
          "timer": "click_window"
        },
        {
          "kind": "set_phase",
          "phase": "idle"
        },
        {
          "kind": "command",
          "command": "relay.set",
          "args": {
            "output": "relay_1",
            "on": false
          }
        },
        {
          "kind": "command",
          "command": "led.effect",
          "args": {
            "output": "strip_1",
            "effect": "rainbow_cycle"
          }
        }
      ]
    },
    {
      "id": "press_1",
      "enabled": true,
      "trigger": {
        "kind": "input_edge",
        "input": "input_1",
        "to": 1
      },
      "conditions": {
        "kind": "phase_is",
        "phase": "idle"
      },
      "actions": [
        {
          "kind": "cancel_timer",
          "timer": "click_window"
        },
        {
          "kind": "set_phase",
          "phase": "press_1"
        }
      ]
    },
    {
      "id": "release_1",
      "enabled": true,
      "trigger": {
        "kind": "input_edge",
        "input": "input_1",
        "to": 0
      },
      "conditions": {
        "kind": "phase_is",
        "phase": "press_1"
      },
      "actions": [
        {
          "kind": "start_timer",
          "timer": "click_window",
          "mode": "oneshot",
          "duration_ms": 700
        },
        {
          "kind": "set_phase",
          "phase": "click_1_wait"
        }
