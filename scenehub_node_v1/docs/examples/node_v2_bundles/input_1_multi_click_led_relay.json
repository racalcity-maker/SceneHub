{
  "version": 2,
  "bundle_id": "input_1_multi_click_led_relay",
  "generation": 2,
  "mode": "standalone",
  "exports": {
    "commands": [],
    "events": [
      {
        "id": "input_1_single_click",
        "label": "Input 1 Single Click"
      },
      {
        "id": "input_1_double_click",
        "label": "Input 1 Double Click"
      },
      {
        "id": "input_1_triple_click",
        "label": "Input 1 Triple Click"
      },
      {
        "id": "input_1_quad_click",
        "label": "Input 1 Quad Click"
      }
    ]
  },
  "emits": [
    "input_1_single_click",
    "input_1_double_click",
    "input_1_triple_click",
    "input_1_quad_click"
  ],
  "limits": {
    "max_action_ms": 50,
    "max_parallel_timers": 1
